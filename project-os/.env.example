DATABASE_URL=postgres://postgres:password@localhost:5432/project_os
PORT=3000
NODE_ENV=development
ANTHROPIC_API_KEY=sk-ant-your-key-here
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
# Optional: fraction of production calls sampled by the LLM judge (default 0.15)
JUDGE_SAMPLE_RATE=0.15

# ── Test DB ───────────────────────────────────────────────────────────────────
# Must point at a DIFFERENT database than DATABASE_URL above.
# Run:  npm run test:db:setup   to create and migrate it.
TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/project_os_test
